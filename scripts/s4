#!/bin/bash
# Blueberry S4 - 两步启动 CLI
# Step 1: sudo ./s4 init  (初始化 CAN)
# Step 2: ./s4 dev        (启动 ROS2 + AGV + Web)

set -e

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
PID_FILE="/tmp/s4_pids"

print() { echo -e "${BLUE}[S4]${NC} $1"; }
ok() { echo -e "${GREEN}[S4]${NC} $1"; }
warn() { echo -e "${YELLOW}[S4]${NC} $1"; }
err() { echo -e "${RED}[S4]${NC} $1"; }

header() {
    echo ""
    echo -e "${CYAN}╔════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           🫐 Blueberry S4 机器人平台                   ${CYAN}║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

check_ros2() {
    [ -f "/opt/ros/humble/setup.bash" ] && source /opt/ros/humble/setup.bash
    command -v ros2 &>/dev/null
}

get_agv_iface() {
    # 动态检测 pcan 接口（实时，不依赖缓存文件）
    for iface in $(ls /sys/class/net/ 2>/dev/null | grep -E '^can' | sort -V); do
        if ip -details link show "$iface" 2>/dev/null | grep -q "pcan:"; then
            echo "$iface"
            return 0
        fi
    done
    # 如果检测失败，尝试缓存文件
    if [ -f /tmp/can_pcan.iface ]; then
        cat /tmp/can_pcan.iface
        return 0
    fi
    # 默认回退
    echo "can3"
}

has_driver_iface() {
    local driver="$1"
    for iface in $(ls /sys/class/net/ 2>/dev/null | grep -E '^can' | sort -V); do
        if ip -details link show "$iface" 2>/dev/null | grep -q "${driver}:"; then
            return 0
        fi
    done
    return 1
}

save_pid() {
    echo $1 >> "$PID_FILE"
}

cleanup() {
    print "正在停止所有服务..."
    if [ -f "$PID_FILE" ]; then
        while read pid; do
            kill $pid 2>/dev/null || true
        done < "$PID_FILE"
        rm -f "$PID_FILE"
    fi
    pkill -f "ros2 launch bringup" 2>/dev/null || true
    pkill -f "rosbridge_server" 2>/dev/null || true
    ok "已停止"
}

# ============ 核心命令 ============

cmd_init() {
    header
    
    if [ "$EUID" -ne 0 ]; then
        err "需要 root: sudo ./s4 init"
        exit 1
    fi
    
    print "╔═══════════════════════════════════════════════════════╗"
    print "║  步骤 1: 初始化 CAN 设备                               ║"
    print "╚═══════════════════════════════════════════════════════╝"
    
    python3 "$SCRIPT_DIR/can_initializer.py"
    
    if ! has_driver_iface "pcan" || ! has_driver_iface "usbcanfd"; then
        err "CAN 初始化失败"
        exit 1
    fi
    
    echo ""
    ok "✅ CAN 初始化完成"
    ok "AGV 接口: $(get_agv_iface) (pcan)"
    ok "WHJ 接口: $(cat /tmp/can_usbcanfd.iface 2>/dev/null || echo 'can?') (usbcanfd)"
    echo ""
    ok "下一步:  ./scripts/s4 dev  (启动 ROS2 + AGV + Web)"
    echo ""
}

cmd_dev() {
    local mode="${1:-hw}"
    header
    
    # 检查 CAN 是否已初始化
    if ! has_driver_iface "pcan"; then
        err "CAN 未初始化"
        print "请先运行: sudo ./s4 init"
        exit 1
    fi
    
    # 检查 ROS2
    print "[1/3] 检查 ROS2..."
    if ! check_ros2; then
        err "ROS2 未安装"
        exit 1
    fi
    
    if [ ! -d "$PROJECT_DIR/install" ]; then
        err "工作空间未编译"
        print "运行: ./s4 build"
        exit 1
    fi
    ok "ROS2 就绪"
    
    # 清理之前的状态
    rm -f "$PID_FILE"
    trap cleanup EXIT INT TERM
    
    source /opt/ros/humble/setup.bash
    source "$PROJECT_DIR/install/setup.bash"
    
    # 启动 AGV
    print "[2/3] 启动 ROS2 + AGV..."
    local agv_iface=$(get_agv_iface)
    ok "检测到 AGV 接口: $agv_iface (pcan)"
    
    ros2 launch bringup robot.launch.py can_agv_interface:=$agv_iface &
    save_pid $!
    sleep 5
    
    if ! pgrep -f "ros2 launch bringup" > /dev/null; then
        err "AGV 启动失败"
        exit 1
    fi
    ok "AGV 已启动"
    
    # 启动 Web
    print "[3/3] 启动 Web Dashboard..."
    IP=$(hostname -I | awk '{print $1}')
    
    # rosbridge_server
    if ros2 pkg list 2>/dev/null | grep -q rosbridge_server; then
        ros2 launch rosbridge_server rosbridge_websocket_launch.xml port:=9091 &
        save_pid $!
        sleep 2
    fi
    
    # HTTP 服务器
    cd "$PROJECT_DIR/web_dashboard"
    python3 -m http.server 8080 &
    save_pid $!
    sleep 1
    
    echo ""
    print "╔═══════════════════════════════════════════════════════╗"
    print "║  ✅ 系统启动完成！                                     ║"
    print "╚═══════════════════════════════════════════════════════╝"
    echo ""
    ok "🌐 访问地址:"
    ok "   AGV 控制: http://$IP:8080/agv_test_control.html"
    ok "   主页:     http://$IP:8080"
    ok "   WebSocket: ws://$IP:9091"
    echo ""
    ok "按 Ctrl+C 停止所有服务"
    wait
}

cmd_check() {
    header
    print "系统状态检查"
    echo ""
    
    check_ros2 && ok "ROS2 Humble" || err "ROS2 未安装"
    [ -d "$PROJECT_DIR/install" ] && ok "工作空间已编译" || warn "未编译"
    
    echo ""
    print "CAN 接口:"
    for iface in $(ls /sys/class/net/ 2>/dev/null | grep -E '^can' | sort -V); do
        driver=$(ip -details link show "$iface" 2>/dev/null | grep -oE "(pcan|usbcanfd|mttcan)" | head -1)
        state=$(ip -br link show "$iface" 2>/dev/null | awk '{print $2}')
        echo "  $iface: $state ($driver)"
    done
    
    if [ -f /tmp/can_pcan.iface ]; then
        echo ""
        ok "AGV -> $(cat /tmp/can_pcan.iface) (pcan)"
        ok "WHJ -> $(cat /tmp/can_usbcanfd.iface) (usbcanfd)"
    fi
    
    echo ""
    pgrep -f "ros2 launch bringup" >/dev/null && ok "AGV 运行中" || warn "AGV 未运行"
    
    echo ""
}

cmd_stop() {
    header
    cleanup
}

cmd_build() {
    header
    check_ros2 || { err "ROS2 未安装"; exit 1; }
    cd "$PROJECT_DIR"
    
    if [ "$1" == "clean" ]; then
        warn "清理..."
        rm -rf build install log
    fi
    
    print "编译中..."
    colcon build --symlink-install "$@"
    ok "编译完成"
}

cmd_help() {
    header
    cat << 'EOF'
Blueberry S4 - 两步启动

使用方法:

  步骤 1: 初始化 CAN (需要 root)
    $ sudo ./scripts/s4 init 

  步骤 2: 启动 ROS2 + AGV + Web
    $ ./scripts/s4 dev   

  然后浏览器访问显示的地址

其他命令:
  ./s4 check      检查系统状态
  ./s4 stop       停止所有服务
  ./s4 build      编译工作空间

EOF
}

cd "$PROJECT_DIR" 2>/dev/null || true

case "${1:-help}" in
    init)   cmd_init ;;
    dev)    shift; cmd_dev "$@" ;;
    check)  cmd_check ;;
    stop)   cmd_stop ;;
    build)  shift; cmd_build "$@" ;;
    help|*) cmd_help ;;
esac
